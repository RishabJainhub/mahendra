# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Production site URL (required on Vercel — use your *.vercel.app URL or custom domain)
# Example: https://mahendra.vercel.app
NEXT_PUBLIC_APP_URL=

# Optional: support phone on login page (suppliers — forgot password)
# Example: +91 98765 43210
NEXT_PUBLIC_SUPPORT_PHONE=

# Optional: extra dev LAN hosts for npm run dev (comma-separated)
# ALLOWED_DEV_ORIGINS=192.168.0.152:3001
